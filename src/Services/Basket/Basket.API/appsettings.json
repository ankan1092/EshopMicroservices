{
  "ConnectionStrings": {
    "Database": "Server=localhost;Port=5433;Database=BasketDb;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost:6379"
  },
  "GrpcSettings": {
    "DiscountUrl": "http://localhost:5052"
  },
  "ResiliencePolicies": {
    "Discount": {
      "RetryCount": 2,
      "InitialDelaySeconds": 1,
      "BackoffMultiplier": 2,
      "CircuitBreakerFailureThreshold": 4,
      "CircuitBreakerTimeoutSeconds": 30
    },
    "Catalog": {
      "RetryCount": 3,
      "InitialDelaySeconds": 1,
      "BackoffMultiplier": 2,
      "CircuitBreakerFailureThreshold": 3,
      "CircuitBreakerTimeoutSeconds": 30
    },
    "Default": {
      "RetryCount": 3,
      "InitialDelaySeconds": 1,
      "BackoffMultiplier": 2,
      "CircuitBreakerFailureThreshold": 3,
      "CircuitBreakerTimeoutSeconds": 30
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Basket.API.Services": "Information"
    }
  },
  "AllowedHosts": "*"
}
